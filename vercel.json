{
    "redirects": [
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "go.nlfts.dev"
                }
            ],
            "destination": "https://nlfts.dev",
            "permanent": true
        },
        {
            "source": "/(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "go.nlfts.dev"
                }
            ],
            "destination": "https://nlfts.dev/$1",
            "permanent": true
        }
    ]
}