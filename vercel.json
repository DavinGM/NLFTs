{
    "redirects": [
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "go.nlfts.dev"
                }
            ],
            "destination": "https://nlfts.dev",
            "permanent": true
        },
        {
            "source": "/((?!discord|whatsapp|github|email|instagram|linkedin).*)",
            "has": [
                {
                    "type": "host",
                    "value": "go.nlfts.dev"
                }
            ],
            "destination": "https://nlfts.dev",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/:slug",
            "has": [
                {
                    "type": "host",
                    "value": "go.nlfts.dev"
                }
            ],
            "destination": "/connected/:slug"
        }
    ]
}